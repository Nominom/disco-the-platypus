{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "ff7f52b1dce040199d1fa87eab363a96",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "VertexSnap (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 2627.0,
            "y": -956.0001220703125,
            "width": 220.000244140625,
            "height": 94.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "20ba3637855744f38623d968b2d9f340"
        },
        {
            "m_Id": "9fa9ca4fc2ce4bd5aa931e8abbb600ef"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "VertexSnap",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float4 clipPos = TransformObjectToHClip(Pos);\n\nfloat2 ndc = clipPos.xy / clipPos.w;\n\nfloat2 pixelPos = round((ndc * 0.5 + 0.5) * _ScreenParams.xy);\n\nndc = (pixelPos / _ScreenParams.xy) * 2.0 - 1.0;\nclipPos.xy = ndc * clipPos.w;\n\nfloat4 worldPos = mul(UNITY_MATRIX_I_VP, clipPos);\nfloat4 objectPos = mul(UNITY_MATRIX_I_M, worldPos / worldPos.w);\nOut = objectPos.xyz;\n"
}

